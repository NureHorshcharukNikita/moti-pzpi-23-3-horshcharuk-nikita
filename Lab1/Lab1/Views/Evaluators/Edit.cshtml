@model Lab1.Models.Evaluator

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Evaluator</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="EvaluatorID" />
            <div class="form-group">
                <label asp-for="EvaluatorName" class="control-label"></label>
                <input asp-for="EvaluatorName" class="form-control" />
                <span asp-validation-for="EvaluatorName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CompetenceRank" class="control-label"></label>
                <input asp-for="CompetenceRank" class="form-control" />
                <span asp-validation-for="CompetenceRank" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
