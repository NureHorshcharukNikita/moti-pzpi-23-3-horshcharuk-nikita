@model Lab3.Models.BordaResultViewModel
@{
    ViewData["Title"] = "Borda rule";
    var n = Model.AlternativeCount;
}

<div class="collective-hub py-2">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Collective voting</a></li>
            <li class="breadcrumb-item active" aria-current="page">Borda</li>
        </ol>
    </nav>

    <h1 class="h2 fw-bold mb-3">Borda result</h1>
    <div class="collective-page-actions mb-4">
        <p class="text-muted mb-0 collective-page-actions__text">
            For @n alternatives: 1st place — <strong>@(n - 1)</strong> points, 2nd — <strong>@(n - 2)</strong>, …, rank @n — <strong>0</strong>.
            The winner is the card with the highest total score across all users.
        </p>
        <div class="collective-page-actions__tools">
            <div class="collective-toolbar">
                <a class="btn btn-sm btn-outline-primary rounded-pill collective-btn" asp-action="Index" title="Back to module">Back</a>
                <a class="btn btn-sm btn-outline-primary rounded-pill collective-btn" asp-action="Profile" title="Voting profile">Profile</a>
                <a class="btn btn-sm btn-outline-primary rounded-pill collective-btn" asp-action="Copeland" title="Copeland result">Copeland</a>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.WinnerName))
    {
        <div class="collective-winner-banner rounded-4 p-4 mb-4">
            <div class="row align-items-center g-3">
                <div class="col-md-8">
                    <p class="text-uppercase small fw-semibold mb-1 opacity-75">Collective winner</p>
                    <h2 class="h4 mb-0 fw-bold">@Model.WinnerName</h2>
                </div>
                <div class="col-md-4 text-md-end">
                    <span class="badge collective-badge fs-6 rounded-pill px-3 py-2">Borda rule</span>
                </div>
            </div>
        </div>
    }

    @if (Model.AggregatedProfileColumns.Count > 0)
    {
        <h2 class="h5 fw-bold mb-3">Borda Voting profile</h2>
        <p class="text-muted small mb-3">
            Columns list how many voters share the same ranking. Rows list cards from best to worst; the last column is the Borda weight for that rank.
        </p>
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="table-responsive">
                <table class="table table-bordered collective-table mb-0 align-middle text-center">
                    <thead class="table-light">
                        <tr>
                            @foreach (var col in Model.AggregatedProfileColumns)
                            {
                                <th scope="col" class="text-nowrap">@col.VoterCount</th>
                            }
                            <th scope="col" class="text-nowrap">Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var rank = 1; rank <= n; rank++)
                        {
                            var points = n - rank;
                            <tr>
                                @foreach (var col in Model.AggregatedProfileColumns)
                                {
                                    <td class="fw-medium">@col.CardsFromBestToWorst[rank - 1]</td>
                                }
                                <td class="fw-semibold text-primary">@points</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <h2 class="h5 fw-bold mb-3">Borda score totals</h2>
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover collective-table mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="ps-4">Card (alternative)</th>
                        <th scope="col" class="text-end pe-4">Borda score total</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var topBorda = Model.Rows.FirstOrDefault()?.TotalScore ?? 0;
                    }
                    @foreach (var row in Model.Rows)
                    {
                        var leader = Math.Abs(row.TotalScore - topBorda) < 1e-9;
                        <tr class="@(leader ? "table-success" : null)">
                            <td class="ps-4 fw-medium">@row.CardName</td>
                            <td class="text-end pe-4 font-monospace">@row.TotalScore.ToString("0.###")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
