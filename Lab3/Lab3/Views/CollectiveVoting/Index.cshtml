@model Lab3.Models.CollectiveVotingPageViewModel
@{
    ViewData["Title"] = "Collective voting";
}

<div class="collective-hub py-2">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Collective voting</li>
        </ol>
    </nav>

    <div class="collective-hero rounded-4 p-4 p-md-5 mb-4 text-white">
        <div class="row align-items-center g-4">
            <div class="col-lg-8">
                <p class="text-uppercase small fw-semibold mb-2 opacity-75 collective-kicker">Lab 3 · group choice</p>
                <h1 class="display-6 fw-bold mb-3">Collective decision support</h1>
                <p class="lead mb-0 opacity-90">
                    Voting profile built from individual card rankings, with outcomes by the
                    <strong>Borda</strong> and <strong>Copeland</strong> rules in the card RPG setting.
                </p>
            </div>
            <div class="col-lg-4">
                <div class="collective-stat-card rounded-3 p-3 text-dark">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">Alternatives (cards)</span>
                        <span class="fs-4 fw-bold text-primary">@Model.AlternativeCount</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted small">Complete voting profiles</span>
                        <span class="fs-4 fw-bold text-success">@Model.ProfileCount</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Warning"] is string w)
    {
        <div class="alert alert-warning shadow-sm border-0 rounded-3" role="alert">@w</div>
    }

    @if (!string.IsNullOrEmpty(Model.WarningMessage))
    {
        <div class="alert alert-info shadow-sm border-0 rounded-3" role="alert">@Model.WarningMessage</div>
    }

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card collective-card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body d-flex flex-column">
                    <div class="collective-icon mb-3 rounded-3 d-inline-flex align-items-center justify-content-center">
                        <span class="fs-3" aria-hidden="true">📋</span>
                    </div>
                    <h2 class="h5 fw-bold">Voting profile</h2>
                    <p class="text-muted flex-grow-1">
                        Table: each row is a user; columns are ranks from best card to worst.
                    </p>
                    @if (Model.HasData)
                    {
                        <a class="btn btn-sm btn-outline-primary rounded-pill collective-btn" asp-action="Profile">Open</a>
                    }
                    else
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill collective-btn" disabled>No data</button>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card collective-card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body d-flex flex-column">
                    <div class="collective-icon collective-icon--borda mb-3 rounded-3 d-inline-flex align-items-center justify-content-center">
                        <span class="fs-3" aria-hidden="true">📊</span>
                    </div>
                    <h2 class="h5 fw-bold">Borda rule</h2>
                    <p class="text-muted flex-grow-1">
                        Sum of points by rank in each ranking: 1st place earns (N−1) points, last place 0.
                    </p>
                    @if (Model.HasData)
                    {
                        <a class="btn btn-sm btn-outline-primary rounded-pill collective-btn" asp-action="Borda">Result</a>
                    }
                    else
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill collective-btn" disabled>No data</button>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card collective-card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body d-flex flex-column">
                    <div class="collective-icon collective-icon--copeland mb-3 rounded-3 d-inline-flex align-items-center justify-content-center">
                        <span class="fs-3" aria-hidden="true">⚔️</span>
                    </div>
                    <h2 class="h5 fw-bold">Copeland rule</h2>
                    <p class="text-muted flex-grow-1">
                        Pairwise majority comparisons: +1 / 0 / −1 for a win, tie, or loss in each duel.
                    </p>
                    @if (Model.HasData)
                    {
                        <a class="btn btn-sm btn-outline-primary rounded-pill collective-btn" asp-action="Copeland">Result</a>
                    }
                    else
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill collective-btn" disabled>No data</button>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (!Model.HasData && Model.AlternativeCount > 0)
    {
        <p class="text-muted small mt-4 mb-0">
            Tip: users complete rankings under <strong>RankCards</strong> (all cards, unique ranks 1…N).
        </p>
    }
</div>
